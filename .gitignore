# =============================================================================
# Pantheon-Core .gitignore
# =============================================================================

# Personal knowledge store — never in git
athenaeum/

# Staging area — unprocessed content
Staging/

# Environment and secrets
.env
*.env
secrets/

# Local config overrides
config.local.yaml

# Runtime and cache
__pycache__/
*.pyc
.chroma/
.qdrant/
node_modules/

# Runtime messages — inter-god communication, never committed
gods/messages/

# Installed god packages — managed by God SDK
.pantheon/

# OS artifacts
.DS_Store
Thumbs.db
