#!/usr/bin/env python3
"""
pantheon-export — Export a god package + optional Codex as a portable tarball.

Usage:
    pantheon-export <god-id> [--include-codex] [--output <path>]

Exports to: ~/pantheon/god-exports/god-{id}-v{version}.tar.gz

The recipient can install with:
    tar xzf god-{id}-v{version}.tar.gz
    pantheon-install god-{id}/
"""
import json
import os
import shutil
import sys
import tarfile
import tempfile
from datetime import datetime

script_dir = os.path.dirname(os.path.abspath(__file__))
lib_dir = os.path.join(script_dir, "lib")
sys.path.insert(0, lib_dir)

from pantheon_sdk import (
    INSTALLED_DIR,
    get_installed_path,
    is_installed,
    get_registry,
    registry_find,
    ATHENAEUM_DIR,
    PANTHEON_DIR,
    print_header,
)


def main():
    if len(sys.argv) < 2:
        print("Usage: pantheon-export <god-id> [--include-codex] [--output <path>]")
        print("\nOptions:")
        print("  --include-codex    Bundle the god's Codex knowledge base")
        print("  --output <path>    Custom output path (default: ~/pantheon/god-exports/)")
        sys.exit(1)

    god_id = sys.argv[1].lower()
    include_codex = "--include-codex" in sys.argv
    output_dir = None

    # Parse --output
    if "--output" in sys.argv:
        idx = sys.argv.index("--output")
        if idx + 1 < len(sys.argv):
            output_dir = os.path.abspath(sys.argv[idx + 1])

    if not output_dir:
        output_dir = os.path.join(PANTHEON_DIR, "god-exports")

    # ── Verify the god exists ────────────────────────────────────────
    registry = get_registry()
    idx, entry = registry_find(registry, god_id)
    if idx is None:
        print(f"Error: god '{god_id}' not found in registry.")
        print(f"  Use 'pantheon-list-gods' to see available gods.")
        sys.exit(1)

    name = entry.get("name", god_id)
    version = entry.get("version", "unknown")
    god_type = entry.get("type", "unknown")

    # ── Verify the package is installed ───────────────────────────────
    if not is_installed(god_id):
        print(f"Error: god '{god_id}' is not installed.")
        print(f"  No package found at: {get_installed_path(god_id)}")
        print(f"  Install it first: pantheon-install <path-to-{god_id}>")
        sys.exit(1)

    package_path = get_installed_path(god_id)

    print_header(f"Exporting {name} v{version}{' (with Codex)' if include_codex else ''}")

    # ── Create temp build directory ───────────────────────────────────
    export_name = f"god-{god_id.replace('god-', '')}"
    with tempfile.TemporaryDirectory(prefix=f"pantheon-export-{export_name}-") as tmpdir:
        export_root = os.path.join(tmpdir, export_name)

        # ── Step 1: Copy package ──────────────────────────────────────
        shutil.copytree(package_path, export_root, symlinks=True)
        print(f"  Package copied from: {package_path}")

        # ── Step 2: Include Codex (if flagged) ────────────────────────
        if include_codex:
            codex_name = f"Codex-{name}"
            codex_src = os.path.join(ATHENAEUM_DIR, codex_name)

            if not os.path.isdir(codex_src):
                print(f"  Warning: Codex directory not found: {codex_src}")
                print(f"  Skipping Codex export.")
            else:
                codex_dst = os.path.join(export_root, "codex")

                # Copy everything except sessions and archive
                os.makedirs(codex_dst, exist_ok=True)

                # Copy INDEX.md
                index_src = os.path.join(codex_src, "INDEX.md")
                if os.path.isfile(index_src):
                    shutil.copy2(index_src, os.path.join(codex_dst, "INDEX.md"))

                # Copy reference dir
                ref_src = os.path.join(codex_src, "reference")
                if os.path.isdir(ref_src):
                    shutil.copytree(ref_src, os.path.join(codex_dst, "reference"))

                # Copy distilled dir
                dist_src = os.path.join(codex_src, "distilled")
                if os.path.isdir(dist_src):
                    shutil.copytree(dist_src, os.path.join(codex_dst, "distilled"))

                # Copy any top-level knowledge files (not subdirs)
                for item in os.listdir(codex_src):
                    item_path = os.path.join(codex_src, item)
                    if os.path.isfile(item_path) and item not in ("INDEX.md",):
                        if item != "INDEX.md":
                            shutil.copy2(item_path, os.path.join(codex_dst, item))

                # Also copy any other subdirectories that aren't sessions/archive
                for item in os.listdir(codex_src):
                    item_path = os.path.join(codex_src, item)
                    if os.path.isdir(item_path) and item not in ("sessions", "archive", "reference", "distilled"):
                        shutil.copytree(item_path, os.path.join(codex_dst, item))

                print(f"  Codex included (sessions and archive excluded)")

        # ── Step 3: Generate or update README ─────────────────────────
        readme_path = os.path.join(export_root, "README.md")
        readme_content = (
            f"# {name}\n\n"
            f"A Pantheon god exported on {datetime.now().strftime('%Y-%m-%d')}.\n\n"
            f"**Version:** {version}\n"
            f"**Type:** {god_type}\n"
            f"**Description:** {entry.get('description', '')}\n"
        )
        if include_codex:
            readme_content += "\n**Includes Codex knowledge base.**\n"
        readme_content += (
            f"\n## Install\n\n"
            f"```\n"
            f"tar xzf {export_name}-v{version}.tar.gz\n"
            f"pantheon-install {export_name}/\n"
            f"```\n"
        )
        with open(readme_path, "w") as f:
            f.write(readme_content)

        # ── Step 4: Create tarball ────────────────────────────────────
        os.makedirs(output_dir, exist_ok=True)
        tarball_name = f"{export_name}-v{version}.tar.gz"
        tarball_path = os.path.join(output_dir, tarball_name)

        with tarfile.open(tarball_path, "w:gz") as tar:
            tar.add(export_root, arcname=export_name)

        print(f"  Tarball created: {tarball_path}")

    # ── Summary ───────────────────────────────────────────────────────
    tarball_size = os.path.getsize(tarball_path)
    if tarball_size < 1024 * 1024:
        size_str = f"{tarball_size / 1024:.1f} KB"
    else:
        size_str = f"{tarball_size / (1024 * 1024):.1f} MB"

    print(f"\n{'─' * 50}")
    print(f"  ✅ {name} v{version} exported")
    print(f"     File: {tarball_path}")
    print(f"     Size: {size_str}")
    if include_codex:
        print(f"     Codex: included")
    print(f"\n  To install on another machine:")
    print(f"     1. Transfer {tarball_name}")
    print(f"     2. tar xzf {tarball_name}")
    print(f"     3. pantheon-install {export_name}/")
    print()


if __name__ == "__main__":
    main()
